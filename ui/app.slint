import { FrameworkState } from "framework/framework.slint";
import { SelectorOption } from "framework/widgets.slint";
import { SelectorOptionsList } from "framework/widgets.slint";
// Types

export enum UiTrayState { Unknown, Empty, Spool, Reading, Ready, Loading, Unloading, Loaded }
// Spool - Spool entered the slot but not yet processed by AMS, so not ready yet
// Ready - there is a spool, it is not loaded to the extruder now
// Loading - during the process of loading into the extruder
// Loaded - in the extruder
// Unloading - during the process of unloading from the extruder
export enum UiFilamentState { Unknown, Known }

export struct UiFilament {
  state: UiFilamentState,
  color: color,
  material: string,
}

export struct UiTray {
  id: int,
  external: bool,
  spool-state: UiTrayState,
  filament: UiFilament,
  k: string,
  tagged: bool,
  weight-display: string,
  used-in-print: bool,
  spool_rec_id: string,
}

export struct UiSpoolInfo {
  id: string,
  color: color,
  material: string,
  k: string,
  weight-core: int,
}

// export enum EncodedAsNew {
//   Unknown,
//   NoChange,
//   No,
//   Yes
// }

export struct EncodeRequest { // EncodeRequest is actually used for FilamentInfo - for Encode as well as View
  // autofilled
  id: string,
  tray-index: int,
  tray-id: int, // from index
  weight-advertised: int, 
  weight-core: int,
  // encoded-as-new: EncodedAsNew,
  weight-new: int, 
  core-name: string, // used to add to list of previously used spools, not encoded to tag
  // manually filled
  brand: string,
  filament-subtype: string,
  color-name: string,
  note: string,
}

// Assistance from rust for more info or formatter info
export struct EncodeRequestDisplay {  // EncodeRequestDisplay is actually used for FilamentInfo - for Encode as well as View
  filament-type: string, // could also get in UI, but easier this way if we have the mechanism
  slicer-name: string,
  color-code: string,
  title-color: color,
  temp-min: int,
  temp-max: int,
  pa-line1: string,
  pa-line2: string,
}

export enum FilamentInfoMode { 
  // Encode,
  View,
  Wizard
}

// Consts

export global AppConsts {
    out property <length> trays-spacing: 4px;
    out property <length> external-tray-separator: 2px;
    out property <brush> no-color: @linear-gradient(45deg, #fff 0%, #333 100%);
    out property <brush> title-gradient: @linear-gradient(180deg, #09009B 0%, #0000CA 39%, #001dff 100%);
    // out property <brush> no-color: @linear-gradient(45deg, #fff 0%, #AAA 54%, #333 100%);
    // out property <brush> no-color: @linear-gradient(180deg, #fff 0%, #666 50%, #333 100%);
}

export enum ControlState {
  Booting,
  // ConnectingToPrinter ,
  BootFailed,
  Ready,
  Reading,
  NewTagScan,
  StagingSelected, // To load
  // EncodeSelectSource,
  // EncodeEditing,
  Encoding,
  FilamentInformation,
  PostAction,
}

export enum SpoolScaleState {
  NotAvailable,
  Unknown,
  Uncalibrated,
  Disconnected,
  Connected,
  Empty,
  Loaded,
}

export enum StatusType {
  Normal,
  Success,
  Error
}

export enum SpoolStagingState {
  Empty,
  Scanned,
  Encoded,
  Unloaded,
  Unchanged,
}

// Functions to call rust
export global AppBackend {
    callback clear-staging();
    callback set-staging-to-tray(tray-id: int);
    // callback encode-tag(encode_request: EncodeRequest) -> int; // returns how long it will try to encode, for timer
    // callback clear-encode-scratchpad();
    // callback notify-start-encode(tray_id: int) -> bool;
    callback read-tag-mode();
    callback web-config-web-app();
    // callback reset-printer();
    callback select-printer(printer: string);
    callback calibrate-scale(weight: int);
    // callback erase-previously-used-core-list();
    // pure callback get-spools-core-list(filter: string) -> [SelectorOption];
    callback get-spool-core-weight(id: int) -> int;
    pure callback get-connected-scale-info() -> string;
    pure callback get-available-scales-info() -> [string];
    // callback encode-web-app();
    callback calc-encode-request-display(mode: FilamentInfoMode);
    callback fill-encode-request-from-spool-id(spool-id: string) -> string;
    callback link_tag_to_spool_id(tag_id: string, spool-id: string, final-step: bool);
    callback set-spool-weight(spool-id: string, weight: int, unused: bool, final-step: bool);
    pure callback recently_added_spool_id_if_untagged() -> string;
}

export enum NewTagScanPage {
    OperationSelect,
    SpoolSelect,
    LinkSpoolDisplay,
    MeasureWeight,
    StatusDisplay,
}

export enum NewTagOperation {
  None,
  LinkTagToSpoolId,
  LinkTagToRecentlyAddedSpool,
}

