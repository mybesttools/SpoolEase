    public function clear-curr-encoding-request() {
        self.curr-encode-request.id = "";
        self.curr-encode-request.weight-advertised = 0;
        self.curr-encode-request.weight-core = 0;
        // self.curr-encode-request.encoded-as-new = EncodedAsNew.Unknown;
        self.curr-encode-request.weight-new = 0;
        self.curr-encode-request.core-name = 0;
        self.curr-encode-request.brand = "";
        self.curr-encode-request.filament-subtype = "";
        self.curr-encode-request.color-name = "";
        self.curr-encode-request.note = "";
        self.curr-encode-request.tray-index = 0;
        self.curr-encode-request.tray-id = -1; // Important, see view_model check of -1

        self.curr-encode-request-display.filament-type = "";
        self.curr-encode-request-display.slicer-name = "";
        self.curr-encode-request-display.color-code = "";
        self.curr-encode-request-display.title-color = #fff;
        self.curr-encode-request-display.temp-min = 0;
        self.curr-encode-request-display.temp-max = 0;
        self.curr-encode-request-display.pa-line1 = "";
        self.curr-encode-request-display.pa-line2 = "";
    }

    // Called from UI in case of UI timeout, can also be called from backend for timeout case
    public function encoding-timeout() {
        self.control-state = ControlState.PostAction;
        self.user-message = "Encoding Tag Timed Out";
        self.user-message-type = StatusType.Error;

        // if want to go back to the encode screen use:
           // self.control-state = ControlState.EncodeEditing;
           // AppBackend.encode-web-app()
           // Don't stop-highlight-tray
        // else
        clear-curr-encoding-request();
        AppBackend.read-tag-mode();
        AppState.stop-highlight-tray();
        // don't call encode-cancel() becasue on timeout we want to show timeout first on display
    }

    public function encode-cancel() {
        clear-curr-encoding-request();
        // AppBackend.clear-encode-scratchpad();
        self.control-state = ControlState.Ready;
        AppBackend.read-tag-mode();
        AppState.stop-highlight-tray();
    }

    public function encode-start() {
        // self.encode-timeout = AppBackend.encode-tag(self.curr-encode-request);
        if self.encode-timeout != 0 { // return value of 0 means there was an error, error will be reported separately
              AppState.start-highlight-tray-forever(self.curr-encode-request.tray-id);
            self.control-state = ControlState.Encoding;
            user-message = "Place Spool Tag\nto Encode";
            user-message-type = StatusType.Normal;
        }
        // clear-curr-encoding-request();
        // AppBackend.notify-post-encode();
    }

    public function show-spoolscale-dialog(message: string, type: StatusType) {
        self.spool-inventory-dialog-message = message;
        self.spool-inventory-dialog-type = type;
    }

    public function spool-scale-connected() {
        self.spool-scale-state = SpoolScaleState.Connected;
        self.spool-scale-flash = true;
        self.spool-scale-after-flash-state = SpoolScaleState.Empty;
    }

    public function spool-scale-disconnected() {
        self.spool-scale-state = SpoolScaleState.Disconnected;
        self.spool-scale-flash = false;
        self.spool-scale-after-flash-state = SpoolScaleState.Disconnected;
    }

    public function spool-scale-uncalibrated() {
        self.spool-scale-state = SpoolScaleState.Uncalibrated;
        self.spool-scale-flash = false;
        self.spool-scale-after-flash-state = SpoolScaleState.Uncalibrated;
    }

