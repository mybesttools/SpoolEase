                        }

                        LabeledInfo {
                            label: "";
                            text: AppState.curr-encode-request-display.pa-line2;
                        }
                    }

                    LabeledInfo {
                        // label-button: mode == FilamentInfoMode.Encode;
                        property <string> core: AppState.curr-encode-request.weight-core > 0 ? "\{AppState.curr-encode-request.weight-core}g" : "—";
                        property <string> new: AppState.curr-encode-request.weight-new > 0 ? "\{AppState.curr-encode-request.weight-new}g" : "—";
                        property <string> advertised: AppState.curr-encode-request.weight-advertised <= 0 ? "—" : ((AppState.curr-encode-request.weight-advertised > 500) && (Math.mod(AppState.curr-encode-request.weight-advertised,500)) == 0) ? "\{AppState.curr-encode-request.weight-advertised / 1000}kg" : "\{AppState.curr-encode-request.weight-advertised}g";
                        label: "Weights:";
                        text: "\{advertised} (Label) / \{core} (Core) / \{new} (New)";
                        // clicked => {
                        //     AppState.encoding-spool-core-visible = true;
                        // }
                    }
