import { Title, MyText,MyButton } from "./framework/widgets.slint";
import { AppBackend, AppState, ControlState, UiTray } from "app.slint";
import { Utils } from "utils.slint";
import { FrameworkState } from "framework/framework.slint";
import { FilamentInfoMode } from "app.slint";
// import { SelectIfNewSpool } from "core-weight.slint";

export component LabeledText inherits Rectangle {
    callback clicked;
    in-out property <bool> label-button: false;
    in-out property <string> label;
    in-out property <string> text;
    in-out property <color> label-color: blue;
    in-out property <color> text-color: black;
    in-out property <length> label-width;
    HorizontalLayout {
        thelabel := MyText {
            width: label-width;
            text: label;
            color: label-button ? black : label-color;
        }

        MyText {
            text: text;
            color: text-color;
        }
    }

    if label-button: MyButton {
        z: -1;
        x: thelabel.x - 4px;
        y: thelabel.y - 4px;
        width: thelabel.width - 1px; // for spacing of 5px (4+1) out of the 10px between elements
        height: thelabel.height + 8px;
        clicked => {
            root.clicked();
        }
    }
}

export component LabeledInfo inherits LabeledText {
    label-width: 90px;
}

export component EncodeTitle inherits Title {
    horizontal-alignment: right;
    text: "To Edit, Scan NFC With Phone   ▶ ▶ ▶\u{00A0}";
    text2: "\{FrameworkState.web-config-url}";
}

export component ViewTitle inherits Title {
    horizontal-alignment: center;
    text: "Filament Information";
}

export component EncodeButtons inherits HorizontalLayout {
    callback encode-clicked;
    callback cancel-clicked;

    Window {
        horizontal-stretch: 1;
    }

    MyButton {
        enabled: AppState.curr-encode-request-display.filament-type != "" && AppState.curr-encode-request-display.color-code != "";
        horizontal-stretch: 1;
        height: 56px;
        text: "Encode";
        clicked => {
            encode-clicked()
        }
    }

    MyButton {
        horizontal-stretch: 1;
        height: 56px;
        text: "Cancel";
        clicked => {
            cancel-clicked()
        }
    }
}

export component ViewButtons inherits HorizontalLayout {
    MyButton {
        horizontal-stretch: 1;
        height: 56px;
        text: "Close";
        clicked => {
            AppState.end-show-filament-information();
        }
    }
}

enum FilamentInfoState {
  DisplayInfo,
  SelectIfNewSpool,
}

